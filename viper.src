getRandomIp = function()
    //1-223.0-255.0-255.0-255
    octets = []
    for i in range(0, 3)
        if i == 0 then
            octets.push(ceil(rnd * 223))
        else
            octets.push(floor(rnd * 256))
        end if
    end for
    return octets.join(".")
end function

